# Google OAuth2 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
# Must match redirect URI in Cloud Console — e.g. http://localhost:8000/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Secret key for session signing (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_me_to_a_random_32_byte_hex

# GA4 Property IDs (find in GA4 → Admin → Property Settings)
GA4_PROPERTY_RH=123456789
GA4_PROPERTY_PMS=123456789
GA4_PROPERTY_AIF=123456789

# LinkedIn OAuth (future — leave blank for now)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Meta / Facebook OAuth (future — leave blank for now)
META_APP_ID=
META_APP_SECRET=
